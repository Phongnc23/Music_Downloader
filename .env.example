# ============================================================
#  Music Downloader Automation - cau hinh thiet bi / ket noi
#  HUONG DAN: copy file nay thanh .env roi sua gia tri cho may ban.
#    Windows : copy .env.example .env
#    Mac/Linux: cp .env.example .env
#  File .env da duoc .gitignore (khong commit cau hinh rieng).
# ============================================================

# --- Thiet bi (BAT BUOC sua) ---
# Lay UDID bang lenh: adb devices  (vd: VSO7UO6DINEQBQPF, emulator-5554)
UDID=YOUR_DEVICE_UDID
DEVICE_NAME=Android Device
PLATFORM_NAME=Android
PLATFORM_VERSION=14

# --- Appium server ---
APPIUM_SERVER_URL=http://127.0.0.1:4723
AUTOMATION_NAME=UiAutomator2

# --- App duoi test (chi doi neu test app khac) ---
APP_PACKAGE=com.musicdownloadapp.musicdownloaderappfree
APP_ACTIVITY=com.example.blue_music_player.MainActivity
APP_NAME=Music Downloader

# --- Package he thong Android (hiem khi can doi) ---
PERMISSION_PACKAGE=com.android.permissioncontroller
SETTINGS_PACKAGE=com.android.settings
INTENT_RESOLVER_PACKAGE=com.android.intentresolver
