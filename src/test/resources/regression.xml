            <class name="testcases.artists.Artists06_Verify_Album_Folders"/>
            <class name="testcases.artists.Artists07_Verify_Detail_Edit_Sheet"/>
        </classes>
    </test>

    <test name="Albums Tests">
        <classes>
            <class name="testcases.albums.Albums01_Verify_UI_Display"/>
            <class name="testcases.albums.Albums02_Verify_Navigation"/>
            <class name="testcases.albums.Albums03_Verify_Sort"/>
            <class name="testcases.albums.Albums04_Verify_Edit_Sheet"/>
            <class name="testcases.albums.Albums05_Verify_Share_With_Limit"/>
            <class name="testcases.albums.Albums06_Verify_Album_Detail"/>
        </classes>
    </test>

    <test name="Playlists Tests">
        <classes>
            <class name="testcases.playlists.Playlists01_Verify_UI_Display"/>
            <class name="testcases.playlists.Playlists02_Verify_Navigation"/>
            <class name="testcases.playlists.Playlists03_Verify_Create_Playlist"/>
