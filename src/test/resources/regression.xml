            <class name="testcases.playlists.Playlists05_Verify_Edit_Actions"/>
            <class name="testcases.playlists.Playlists06_Verify_Share_With_Limit"/>
        </classes>
    </test>

    <test name="Search In Library Tests">
        <classes>
            <class name="testcases.searchlibrary.SearchLibrary01_Verify_Navigation"/>
            <class name="testcases.searchlibrary.SearchLibrary02_Verify_UI_Tabs"/>
            <class name="testcases.searchlibrary.SearchLibrary03_Verify_Search"/>
            <class name="testcases.searchlibrary.SearchLibrary04_Verify_Tab_Filtering"/>
            <class name="testcases.searchlibrary.SearchLibrary05_Verify_Result_Navigation"/>
        </classes>
    </test>

</suite>