            <class name="testcases.tracks.Tracks03_Verify_Play_Controls"/>
            <class name="testcases.tracks.Tracks04_Verify_Edit_Sheet"/>
            <class name="testcases.tracks.Tracks05_Verify_Edit_Actions"/>
            <class name="testcases.tracks.Tracks06_Verify_Player_Screens"/>
            <class name="testcases.tracks.Tracks07_Verify_Queue_Advanced"/>
            <class name="testcases.tracks.Tracks08_Verify_Select_Mode"/>
        </classes>
    </test>

    <test name="Artists Tests">
        <classes>
            <class name="testcases.artists.Artists01_Verify_UI_Display"/>
            <class name="testcases.artists.Artists02_Verify_Navigation"/>
            <class name="testcases.artists.Artists03_Verify_Edit_Sheet"/>
