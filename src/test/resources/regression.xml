            <class name="testcases.home.Home02_Verify_Bypass_Ad_After_Interaction"/>
            <class name="testcases.home.Home06_Verify_Exit_Dialog"/>
        </classes>
    </test>

    <test name="Search Tests">
        <classes>
            <class name="testcases.search.Search01_Verify_Navigation"/>
            <class name="testcases.search.Search02_Verify_Input_And_Suggestions"/>
            <class name="testcases.search.Search03_Verify_Results_And_Download"/>
            <class name="testcases.search.Search04_Verify_E2E_Download_And_Verify"/>
        </classes>
    </test>

    <test name="Menu Tests">
        <classes>
            <class name="testcases.menu.Menu01_Verify_Drawer_Display"/>
            <class name="testcases.menu.Menu02_Verify_Item_Navigation"/>
            <class name="testcases.menu.Menu03_Verify_Sleep_Timer"/>
            <class name="testcases.menu.Menu04_Verify_Settings_Screen"/>
            <class name="testcases.menu.Menu05_Verify_Exit_Flow"/>
        </classes>
    </test>

    <test name="Tracks Tests">
        <classes>
            <class name="testcases.tracks.Tracks01_Verify_UI_Display"/>
