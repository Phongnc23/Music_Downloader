<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Music Downloader Test Suite" verbose="1">
    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>

    <test name="Home Tests">
        <classes>
            <class name="testcases.home.Home01_Verify_App_Launched"/>
            <class name="testcases.home.Home03_Verify_UI_Display"/>
            <class name="testcases.home.Home05_Verify_Bottom_Nav_And_Mini_Player"/>
